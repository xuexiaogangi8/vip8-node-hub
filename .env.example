PORT=3010
PUBLIC_BASE_URL=https://your-domain.example.com
SITE_NAME=Your Site Name

# Admin
SITE_PASSWORD=change_me
SITE_SESSION_SECRET=change_me_to_a_long_random_string

# Member session
MEMBER_SESSION_SECRET=change_me_to_another_long_random_string

# Telegram
TG_BOT_TOKEN=
TG_WEBHOOK_SECRET=
TG_ALLOW_CHAT_IDS=

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 留空时默认用: SITE_NAME <SMTP_USER>
SMTP_FROM=

# Runtime
SUBSCRIPTION_SYNC_INTERVAL_MS=60000
AUTO_CHECK_INTERVAL_MS=1800000
CHECK_TIMEOUT_MS=3000
AUTO_CHECK_BATCH_SIZE=80
